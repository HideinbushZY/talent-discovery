# ─────────────────────────────────────────────────────────────
# 复制为 .env 并填入你自己的真实值。.env 已被 .gitignore 忽略。
# 获取方式见 README.md / api-setup-guide.md
# ─────────────────────────────────────────────────────────────

# 公网部署必填：访问口令（用户名任意，密码=此值）。留空=本地开放，切勿用于公网。
APP_PASSWORD=

# GitHub 个人访问令牌：只读公开数据即可（fine-grained: Public Repositories read-only）
GITHUB_TOKEN=

# X (Twitter) API v2 Bearer Token（按量付费 console.x.com；原样粘贴控制台显示的串）
X_API_BEARER_TOKEN=

# LLM = Kimi / Moonshot（OpenAI 兼容接口；platform.moonshot.cn 获取 key）
KIMI_API_KEY=                    # sk- 开头
KIMI_BASE_URL=https://api.moonshot.cn/v1   # 国际站为 https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6            # 阶段1 难题理解/路由用（重质量）
LLM_REVIEW_MODEL=moonshot-v1-128k   # 阶段3 复核/打分用（非思考、更快；重速度）

# 多供应商兜底（主失败后自动降级）：
LLM_FALLBACK_MODEL=moonshot-v1-128k   # 第一层兜底：同 key 的非思考模型（默认已配，留空可关）
# 第二层兜底：完全不同的供应商（可选，需另一把 key）
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_PROVIDER_MODEL=

# ── 成本 / 范围控制 ─────────────────────────────────────────
CHINA_FIT_BOOST=30               # "中国优先"开关打开时的加成强度（rank=加权分+本值×china_fit分）。0=关闭
X_READ_BUDGET=300                 # 每次搜索最多读多少条 X 帖子（先小后大）
X_SESSION_READ_CAP=3000          # 进程级 X 读取总上限（防多次/并发搜索把花费叠加到失控，~$15）
TOP_N_PER_CHANNEL=40              # 每个通道进入评分的候选数
PORT=8848

# ── 可观测性 ────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG / INFO / WARNING …
LOG_FORMAT=json                  # json（便于日志系统解析）| plain（本地易读）
SENTRY_DSN=                      # 填了且 pip install sentry-sdk，异常自动上报 Sentry
